font-family = "Monaspace Neon NF"
# font-family = "MonaspaceNeonNF"
# font-family = "Maple Mono NF"
macos-titlebar-style = hidden
theme = kanagawa-lotus
minimum-contrast = 1.1
window-padding-balance = true
command="/opt/homebrew/bin//nu"
custom-shader=./shaders/cursor_smear_fade.glsl
keybind=clear
keybind=cmd+v=paste_from_clipboard

keybind = shift+enter=text:\x1b\r
keybind = global:alt+shift+r=toggle_quick_terminal
